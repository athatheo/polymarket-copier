# Polymarket Copy Trading Bot Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED - See README for how to obtain these
# =============================================================================

# The wallet address you want to copy trades from
# Find this at: https://polymarket.com/profile/USERNAME -> look at the URL or profile
TARGET_WALLET=0x...

# Your Ethereum wallet private key (must have USDC on Polygon)
# This is the ONLY credential needed - API keys are derived automatically
# WARNING: Keep this secret! Never commit to git.
# 
# HOW TO GET THIS:
# Option A - MetaMask: Settings > Security & Privacy > Reveal Secret Recovery Phrase
#            Then derive private key for specific account
# Option B - Export from wallet: Most wallets have "Export Private Key" option
# Option C - Create new wallet: Use any Ethereum wallet, fund with USDC on Polygon
#
PRIVATE_KEY=0x...

# =============================================================================
# OPTIONAL - Safety Settings
# =============================================================================

# Maximum allowed slippage percentage (default: 10%)
# If market price moved more than this since target's trade, skip it
MAX_SLIPPAGE_PERCENT=10.0

# Maximum USD per single trade (default: $100)
MAX_TRADE_USD=100.0

# Minimum USD per trade to avoid dust (default: $1)
MIN_TRADE_USD=1.0

# =============================================================================
# OPTIONAL - Operation Mode
# =============================================================================

# Set to "true" to log trades without executing (default: true for safety)
DRY_RUN=true

# How often to check for new trades in seconds (default: 10)
POLL_INTERVAL_SECONDS=10

# =============================================================================
# OPTIONAL - Advanced
# =============================================================================

# SQLite database file path
DATABASE_PATH=copied_trades.db

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
